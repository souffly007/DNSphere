<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Nom -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_name"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etScheduleName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/schedule_default_name"
            android:textColor="@android:color/white"
            android:textColorHint="@color/gray"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="@android:drawable/editbox_background"/>

        <!-- Heures -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_time_range"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnStartTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="08:00"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  →  "
                android:textColor="@android:color/white"
                android:textSize="18sp"/>

            <Button
                android:id="@+id/btnEndTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="18:00"
                android:textSize="16sp"/>

        </LinearLayout>

        <!-- Jours -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_days"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <CheckBox
                android:id="@+id/cbMon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="L"
                android:checked="true"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbTue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="M"
                android:checked="true"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbWed"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="M"
                android:checked="true"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbThu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="J"
                android:checked="true"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbFri"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="V"
                android:checked="true"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbSat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="S"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

            <CheckBox
                android:id="@+id/cbSun"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="D"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"/>

        </LinearLayout>

        <!-- Action -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_action"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <RadioGroup
            android:id="@+id/radioGroupAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioEnable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/schedule_action_enable"
                android:textColor="@android:color/white"
                android:checked="true"
                android:buttonTint="@color/green"
                android:paddingStart="8dp"/>

            <RadioButton
                android:id="@+id/radioDisable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/schedule_action_disable"
                android:textColor="@android:color/white"
                android:buttonTint="@color/green"
                android:paddingStart="8dp"/>

        </RadioGroup>

    </LinearLayout>

</ScrollView>